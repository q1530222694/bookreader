<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- 启用 App Sandbox（必需） -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	
	<!-- 【图片转PDF修复】允许读取用户通过文件选择器选中的文件（仅读取） -->
	<!-- 该权限使得 file_picker 能够访问用户手动选择的图片文件 -->
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	
	<!-- 允许读写下载文件夹 -->
	<key>com.apple.security.files.downloads.read-write</key>
	<true/>
	
	<!-- 允许读写文档文件夹 -->
	<key>com.apple.security.files.documents.read-write</key>
	<true/>
	
	<!-- 允许读写桌面文件夹 -->
	<key>com.apple.security.files.desktop.read-write</key>
	<true/>
	
	<!-- 【图片转PDF修复】允许读写用户选择的文件位置 -->
	<!-- 支持在用户选定的任意文件夹保存 PDF 导出结果 -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
</dict>
</plist>
